# Backend environment template — copy to .env and fill in.
# Read by django-environ in ecommerce/settings.py.

# --- Core ----------------------------------------------------------------

# Django secret key. Generate one with `python -c "import secrets; print(secrets.token_urlsafe(50))"`.
SECRET_KEY=changeme

# True locally, False in production.
DEBUG=True

# Used for CORS_ALLOWED_ORIGINS + CSRF_TRUSTED_ORIGINS. Vite dev default below.
FRONTEND_URL=http://localhost:5173

# --- Database ------------------------------------------------------------
# Leave DB_NAME unset to fall back to local SQLite (db.sqlite3).
# Set all four to switch to PostgreSQL (production).

# DB_NAME=pokebin
# DB_USER=pokebin
# DB_PASSWORD=
# DB_HOST=localhost

# --- Object storage (Cloudflare R2 preferred, S3 fallback) --------------
# Set USE_R2=True to push media to R2; otherwise leave unset for filesystem.

USE_R2=False
# R2_ACCOUNT_ID=
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_CUSTOM_DOMAIN=media.pokebin.app   # optional; else <bucket>.r2.dev is used

# Fallback only — used if USE_R2 is False/unset.
# AWS_STORAGE_BUCKET_NAME=

# --- Email (SendGrid SMTP) ----------------------------------------------

SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=Pokebin <no-reply@pokebin.app>

# --- eBay integration ---------------------------------------------------
# Sandbox keys live in the eBay developer console under "Sandbox Keys";
# production under "Production Keys". RuName is the redirect identifier
# you registered for the OAuth flow.

EBAY_ENV=sandbox            # 'sandbox' or 'production'
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_RU_NAME=

# Optional comma-separated allowlist used as a backstop when
# EbayCategoryMapping is empty (e.g. before initial admin setup).
# Values are eBay store-category PATH NAMES (the offer's storeCategoryNames,
# e.g. "/Pokemon/Cards"), NOT numeric category IDs.
# EBAY_STORE_CATEGORY_IDS=/Pokemon/Cards,/Pokemon/Plushies

# Category slug that allowlisted-but-unmapped items are filed under. Required
# whenever EBAY_STORE_CATEGORY_IDS is used (otherwise those items error out).
# EBAY_FALLBACK_CATEGORY_SLUG=cards